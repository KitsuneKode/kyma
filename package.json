{
  "name": "kyma",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:web": "next dev --turbopack",
    "dev:stack": "env -u NO_COLOR FORCE_COLOR=1 concurrently -n convex,web -c \"bgBlue.bold,bgMagenta.bold\" -p \"[{time} {name}]\" -t \"HH:mm:ss\" --pad-prefix --kill-others-on-fail \"bun run convex:dev\" \"bun run dev:web\"",
    "dev:full": "env -u NO_COLOR FORCE_COLOR=1 concurrently -n convex,web,agent -c \"bgBlue.bold,bgMagenta.bold,bgGreen.bold\" -p \"[{time} {name}]\" -t \"HH:mm:ss\" --pad-prefix --kill-others-on-fail \"bun run convex:dev\" \"bun run dev:web\" \"bun run agent:dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint:staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "convex:dev": "CONVEX_AGENT_MODE=anonymous bunx convex dev",
    "convex:once": "CONVEX_AGENT_MODE=anonymous bunx convex dev --once",
    "agent:dev": "bun run agents/worker.ts dev",
    "agent:start": "bun run agents/worker.ts start",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.2.3",
    "@livekit/agents": "^1.2.8",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/three": "^0.184.0",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.35.1",
    "inngest": "^4.2.4",
    "livekit-client": "^2.18.4",
    "livekit-server-sdk": "^2.15.1",
    "motion": "^12.38.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.3.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@kitsunekode/sweep": "^0.1.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "postcss": "^8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
